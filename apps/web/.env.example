# Copy this file to .env.local and fill in the real values.
# On a machine linked to Vercel you can fetch them with: vercel env pull .env.local
# Find the values in Supabase: Project → Settings → API.

# --- Public (safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Secret (server-only — NEVER expose to the browser or commit the real value) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Optional: integration tests only ---
# Overrides the local Supabase DB connection used by `npm run test:integration`.
# Leave unset to use the local stack (`supabase start`).
# SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
