# Copy this file to .env.local and fill in the real values.
# On a machine linked to Vercel you can fetch them with: vercel env pull .env.local
# Find the values in Supabase: Project → Settings → API.

# --- Public (safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Secret (server-only — NEVER expose to the browser or commit the real value) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- NestJS API (strangler migration) ---
# Base URL of the apps/api service. Local: http://127.0.0.1:6061.
# Prod (inert until modules are flipped): https://chidental-api-production.up.railway.app
NEXT_PUBLIC_API_URL=http://127.0.0.1:6061
# Comma-separated data modules served by the API instead of Next queries.
# Empty/unset => every module served by Next, as today. e.g. USE_API_MODULES=products
# All 9 modules are implemented on the API (reads + writes). Flip one at a time,
# soak, then add the next. Reads and writes are separate flags so reads can lead:
#   reads:  products, customers, work, invoices, dashboard, reports
#   writes: customer-actions, work-actions, invoice-actions
# Suggested rollout order (lowest blast radius first):
#   products → customers → work → dashboard → reports → invoices
#   → customer-actions → work-actions → invoice-actions (money/audit, last)
USE_API_MODULES=

# --- Optional: integration tests only ---
# Overrides the local Supabase DB connection used by `npm run test:integration`.
# Leave unset to use the local stack (`supabase start`).
# SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
