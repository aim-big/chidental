# Copy to apps/api/.env for local dev. Values come from `supabase status` (local)
# or the Supabase dashboard (staging/prod). The API uses the service-role key and
# verifies user JWTs against the same project.
NODE_ENV=development
API_PORT=6061

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Comma-separated web origins allowed to call the API (the Vercel app).
CORS_ORIGINS=http://localhost:6060
